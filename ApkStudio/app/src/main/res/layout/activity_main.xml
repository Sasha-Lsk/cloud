<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header"
        android:paddingTop="36dp"
        android:paddingBottom="24dp"
        android:paddingLeft="22dp"
        android:paddingRight="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#0E1116"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle"
            android:textColor="#0E1116"
            android:alpha="0.75"
            android:textSize="14sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Decompile card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Распаковка"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/apk_label"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"/>

                <Spinner
                    android:id="@+id/spinner_apk"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_bg"
                    android:layout_marginTop="6dp"
                    android:paddingLeft="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btn_smali"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:layout_marginRight="6dp"
                        android:text="@string/to_smali"
                        android:textColor="#0E1116"
                        android:textStyle="bold"
                        android:background="@drawable/btn_accent"/>

                    <Button
                        android:id="@+id/btn_java"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="52dp"
                        android:layout_marginLeft="6dp"
                        android:text="@string/to_java"
                        android:textColor="@color/accent2"
                        android:textStyle="bold"
                        android:background="@drawable/btn_outline"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Build card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card"
                android:padding="18dp"
                android:layout_marginTop="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Сборка"
                    android:textColor="@color/accent"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/proj_label"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"/>

                <Spinner
                    android:id="@+id/spinner_proj"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_bg"
                    android:layout_marginTop="6dp"
                    android:paddingLeft="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_build"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:text="@string/build_apk"
                    android:textColor="#0E1116"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:background="@drawable/btn_accent"
                    app:cornerRadius="14dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto"/>
            </LinearLayout>

            <!-- Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btn_refresh"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginRight="6dp"
                    android:text="@string/refresh"
                    android:textColor="@color/text"
                    android:background="@drawable/spinner_bg"/>

                <Button
                    android:id="@+id/btn_guide"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginLeft="6dp"
                    android:text="@string/guide"
                    android:textColor="@color/accent2"
                    android:background="@drawable/btn_outline"/>
            </LinearLayout>

            <!-- Console -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Журнал"
                android:textColor="@color/text_dim"
                android:textSize="12sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/console"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@drawable/console_bg"
                android:padding="12dp"
                android:textColor="@color/console_text"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:scrollbars="vertical"
                android:gravity="top"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
