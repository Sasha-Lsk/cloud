<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_root">

    <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_bar"
        android:paddingLeft="4dp"
        android:paddingRight="4dp">

        <ImageButton
            android:id="@+id/exp_menu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_menu"
            android:contentDescription="@string/cd_menu" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/tab_explorer"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ ПРОВОДНИКА -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_bar"
        android:paddingLeft="14dp"
        android:paddingRight="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/exp_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПРОВОДНИК"
                android:textColor="@color/spoiler_blue"
                android:textSize="13sp"
                android:letterSpacing="0.08"
                android:singleLine="true"
                android:ellipsize="end"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/exp_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/exp_source"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_exp_open"
            android:contentDescription="Открыть проект" />

        <ImageButton
            android:id="@+id/exp_new_file"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_exp_newfile"
            android:contentDescription="Новый файл" />

        <ImageButton
            android:id="@+id/exp_new_folder"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_exp_newfolder"
            android:contentDescription="Новая папка" />

        <ImageButton
            android:id="@+id/exp_refresh"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_exp_refresh"
            android:contentDescription="Обновить" />

        <ImageButton
            android:id="@+id/exp_more"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_exp_more"
            android:contentDescription="Действия" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ДЕРЕВО ФАЙЛОВ + нижняя панель мультивыделения -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/exp_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/exp_tree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="80dp" />
        </ScrollView>

        <TextView
            android:id="@+id/exp_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Проводник пуст.\nСоздайте файл или папку."
            android:gravity="center"
            android:textColor="@color/text_hint"
            android:textSize="15sp"
            android:visibility="gone" />

        <!-- Панель мультивыделения (снизу) -->
        <LinearLayout
            android:id="@+id/exp_select_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_select_bar"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <ImageButton
                android:id="@+id/sb_cancel"
                android:layout_width="42dp"
                android:layout_height="46dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_sb_close"
                android:contentDescription="Выйти" />

            <TextView
                android:id="@+id/sb_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Выбрано: 0"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginLeft="4dp" />

            <ImageButton
                android:id="@+id/sb_all"
                android:layout_width="42dp"
                android:layout_height="46dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_sb_all"
                android:contentDescription="Выделить все" />

            <ImageButton
                android:id="@+id/sb_none"
                android:layout_width="42dp"
                android:layout_height="46dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_sb_none"
                android:contentDescription="Снять выделение" />

            <ImageButton
                android:id="@+id/sb_copy"
                android:layout_width="42dp"
                android:layout_height="46dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_sb_copy"
                android:contentDescription="Копировать" />

            <ImageButton
                android:id="@+id/sb_move"
                android:layout_width="42dp"
                android:layout_height="46dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_sb_move"
                android:contentDescription="Переместить" />

            <ImageButton
                android:id="@+id/sb_zip"
                android:layout_width="42dp"
                android:layout_height="46dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_sb_zip"
                android:contentDescription="Сжать в zip" />

            <ImageButton
                android:id="@+id/sb_delete"
                android:layout_width="42dp"
                android:layout_height="46dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_sb_delete"
                android:contentDescription="Удалить" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
