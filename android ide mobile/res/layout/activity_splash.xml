<?xml version="1.0" encoding="utf-8"?>
<!-- Стартовый сплеш: изображение заполняет ВЕСЬ экран (scaleType=fitXY), точно
     так же, как фон темы splash_bg (bitmap gravity="fill"). Благодаря совпадению
     режимов первый мгновенный кадр темы и этот layout выглядят одинаково — картинка
     сразу на весь экран, без «скачка» с маленькой на большую. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <ImageView
        android:id="@+id/splash_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/ic_logo"
        android:contentDescription="IDE Mobile" />

</FrameLayout>
