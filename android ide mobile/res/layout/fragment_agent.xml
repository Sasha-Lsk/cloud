<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_root">

    <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_bar"
        android:paddingLeft="4dp"
        android:paddingRight="4dp">

        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_menu"
            android:contentDescription="@string/cd_menu" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/agent_title"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_settings"
            android:contentDescription="@string/cd_settings" />

        <ImageButton
            android:id="@+id/btn_chats"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_toLeftOf="@id/btn_settings"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_chats"
            android:contentDescription="@string/cd_chats" />
    </RelativeLayout>

    <!-- СТРОКА ВЫБОРА МОДЕЛИ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_bar"
        android:paddingLeft="12dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/provider_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginRight="8dp" />

        <LinearLayout
            android:id="@+id/btn_model"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_model"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_model">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_chevron" />

            <!-- Две строки: провайдер (голубой, мельче) сверху, модель (мелким
                 светлым) снизу — как в web-версии. -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/model_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_model"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textColor="@color/spoiler_blue"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/model_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textColor="@color/text_primary"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_clear"
            android:layout_width="42dp"
            android:layout_height="40dp"
            android:layout_marginLeft="8dp"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:background="@drawable/bg_clear"
            android:src="@drawable/ic_broom"
            android:contentDescription="@string/cd_clear" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ОБЛАСТЬ ЧАТА + выпадающий список моделей поверх неё -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <ScrollView
        android:id="@+id/chat_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/chat_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp" />
    </ScrollView>

    <!-- Выпадающий список моделей (раскрывается кликом по модели в шапке) -->
    <LinearLayout
        android:id="@+id/model_dropdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/bg_bar"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/dd_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="42dp"
                android:background="@drawable/bg_input"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:hint="Поиск по названию/id…"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:singleLine="true"
                android:inputType="text" />

            <ImageButton
                android:id="@+id/dd_refresh"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginLeft="8dp"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:background="@drawable/btn_normal"
                android:src="@drawable/ic_refresh"
                android:contentDescription="Обновить список моделей" />
        </LinearLayout>

        <TextView
            android:id="@+id/dd_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="6dp">

            <LinearLayout
                android:id="@+id/dd_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    </FrameLayout>

    <!-- ПРЕВЬЮ ПРИКРЕПЛЁННЫХ ФАЙЛОВ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_bar"
        android:scrollbars="none"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="6dp">

        <LinearLayout
            android:id="@+id/attach_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone" />
    </HorizontalScrollView>

    <!-- ПАНЕЛЬ ВВОДА -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_bar"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btn_attach"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_attach"
            android:contentDescription="@string/cd_attach" />

        <EditText
            android:id="@+id/input_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="46dp"
            android:maxLines="4"
            android:background="@drawable/bg_field"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical"
            android:hint="@string/hint_message"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:inputType="textMultiLine|textCapSentences" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginLeft="8dp"
            android:scaleType="centerInside"
            android:padding="11dp"
            android:background="@drawable/bg_send"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/cd_send" />
    </LinearLayout>

</LinearLayout>
